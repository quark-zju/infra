[Unit]
Description=OpenCode Web
After=network.target
StartLimitIntervalSec={{ opencode_start_limit_interval_sec }}
StartLimitBurst={{ opencode_start_limit_burst }}

[Service]
Type=simple
User={{ opencode_user }}
Group={{ opencode_group }}
WorkingDirectory={{ opencode_home }}
Environment=HOME={{ opencode_home }}
Environment=AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
Environment=PATH=/home/opencode/.npm/global/bin:/home/opencode/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
EnvironmentFile={{ opencode_env_file }}
ExecStart={{ opencode_npm_prefix.stdout }}/bin/opencode serve --print-logs --log-level {{ opencode_log_level }} --hostname {{ opencode_web_hostname }} --port {{ opencode_web_port }}
Restart=always
RestartSec={{ opencode_restart_sec }}
OOMPolicy=continue
MemoryMax={{ opencode_memory_max }}
MemoryHigh={{ opencode_memory_high }}
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX AF_NETLINK
LockPersonality=true
RestrictRealtime=true
RestrictNamespaces=true
ReadWritePaths={{ opencode_home }}

[Install]
WantedBy=multi-user.target
